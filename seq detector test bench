module tb_seqdet;
    reg clk = 0, reset = 0, data_in;
    wire led1, led2;

    sequence_detector uut(clk, reset, data_in, led1, led2);

    always #5 clk = ~clk;  // 100 MHz clock

    initial begin
        reset = 1; #10;
        reset = 0;

        // Bit stream: 1 0 1 1 0 1
        data_in = 1; #10;
        data_in = 0; #10;
        data_in = 1; #10; // detected here
        data_in = 1; #10;
        data_in = 0; #10;
        data_in = 1; #10; // detected again
        $stop;
    end
endmodule
